VIRTUAL_ENV="/home/llandre/.venvs/retriva-v0.1"
PYTHONPATH="/mnt/shared/implementation/retriva/src"

OPENROUTER_OPENAI_API_KEY="put your key here"

# Note: Pydantic BaseSettings does not support bash-style variable interpolation (e.g. $VAR). 
# However, you do not need to repeat the API key for every service. The 'model_post_init' 
# method in 'src/retriva/config.py' automatically falls back EMBEDDING_OPENAI_API_KEY, 
# CHAT_OPENAI_API_KEY, and VISUAL_OPENAI_API_KEY to the OPENROUTER_OPENAI_API_KEY if they 
# are left omitted or empty here.

INGESTION_API_PORT = "8000"
OPENAI_API_PORT = "8001"
UI_PORT = "3000"

# Embedding model
# EMBEDDING_BASE_URL="http://192.168.1.64:8000/v1"
EMBEDDING_BASE_URL = "https://openrouter.ai/api/v1"
EMBEDDING_MODEL = "baai/bge-m3"
EMBEDDING_DIMENSION = 1024

# Chat model
# CHAT_BASE_URL="http://192.168.1.64:8001/v1"
CHAT_BASE_URL = "https://openrouter.ai/api/v1"
CHAT_MODEL = "qwen/qwen3.5-27b"
CHAT_TEMPERATURE = 0.0
CHAT_TOP_P = 0.9

# Visual model
VISUAL_BASE_URL = "https://openrouter.ai/api/v1"
VISUAL_MODEL = "qwen/qwen3-vl-32b-instruct"
VISUAL_MAX_TOKENS = 2048
VISUAL_TEMPERATURE = 0.0

# Retriever business logic
RETRIEVER_TOP_K = 20
