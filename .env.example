VIRTUAL_ENV="/home/llandre/.venvs/retriva-v0.1"
PYTHONPATH="/mnt/shared/implementation/retriva/src"

OPENROUTER_OPENAI_API_KEY="put your key here"

# Note: Pydantic BaseSettings does not support bash-style variable interpolation (e.g. $VAR). 
# However, you do not need to repeat the API key for every service. The 'model_post_init' 
# method in 'src/retriva/config.py' automatically falls back EMBEDDING_OPENAI_API_KEY, 
# CHAT_OPENAI_API_KEY, VISUAL_OPENAI_API_KEY, and RETRIEVAL_RERANK_API_KEY to the 
# OPENROUTER_OPENAI_API_KEY if they are left omitted or empty here.

INGESTION_API_PORT = "8000"
OPENAI_API_PORT = "8001"
UI_PORT = "3000"

# Embedding model
# EMBEDDING_BASE_URL="http://192.168.1.64:8000/v1"
EMBEDDING_BASE_URL = "https://openrouter.ai/api/v1"
EMBEDDING_MODEL = "baai/bge-m3"
EMBEDDING_DIMENSION = 1024

# Chat model
# CHAT_BASE_URL="http://192.168.1.64:8001/v1"
CHAT_BASE_URL = "https://openrouter.ai/api/v1"
CHAT_MODEL = "qwen/qwen3.5-27b"
CHAT_TEMPERATURE = 0.0
CHAT_TOP_P = 0.9

# Visual model
VISUAL_BASE_URL = "https://openrouter.ai/api/v1"
VISUAL_MODEL = "qwen/qwen3-vl-32b-instruct"
VISUAL_MAX_TOKENS = 2048
VISUAL_TEMPERATURE = 0.0

# Retriever business logic
RETRIEVER_TOP_K = 200

# Retrieval re-ranking (two-stage)
# When enabled, vector search candidates are re-scored by a cross-encoder
# model and only the top RETRIEVAL_RERANK_TOP_N are kept for the LLM context.
# RETRIEVAL_RERANK_CANDIDATES controls how many vector-search hits enter the
# reranker (must be <= RETRIEVER_TOP_K). Documents exceeding
# RETRIEVAL_RERANK_MAX_LENGTH chars are truncated before scoring.
ENABLE_RETRIEVAL_RERANKING = true
RETRIEVAL_RERANK_MODEL = "cohere/rerank-v3.5"
RETRIEVAL_RERANK_BASE_URL = "https://openrouter.ai/api/v1"
# RETRIEVAL_RERANK_API_KEY — falls back to OPENROUTER_OPENAI_API_KEY
RETRIEVAL_RERANK_CANDIDATES = 100
RETRIEVAL_RERANK_TOP_N = 30
RETRIEVAL_RERANK_BATCH_SIZE = 100
RETRIEVAL_RERANK_MAX_LENGTH = 4096

# Hybrid retrieval selection
# Merges the top M re-ranked results with the top L vector-search
# results (deduplicated), recovering implicit evidence.
# Only effective when ENABLE_RETRIEVAL_RERANKING is also true.
ENABLE_HYBRID_RETRIEVAL_SELECTION = true
HYBRID_RERANK_KEEP_TOP_M = 4
HYBRID_VECTOR_KEEP_TOP_L = 2

# Internal profiler
ENABLE_INTERNAL_PROFILER = false

# Citation Metadata Truncation (SSE payload control)
CITATIONS_MAX_SNIPPET_LEN = 2000
CITATIONS_MAX_COUNT = 0
CITATIONS_MAX_METADATA_ENTRIES = 0

MAX_CITATIONS = 25
